{
  "name": "Elena - Grupo Soler",
  "description": "Asesora IA para los 4 negocios del Grupo Soler (Glass, Esmeraldas, Autos, Inversiones) en Costa Rica. Identifica marca por contexto y responde con KB específica.",
  "model": "claude-sonnet-4-5-20250929",
  "max_tokens": 1024,
  "temperature": 0.7,
  "system_prompt_file": "elena-master-system-prompt.md",
  "tools": [
    {
      "name": "get_business_kb",
      "description": "Returns the full KB for a specific business",
      "input_schema": {
        "type": "object",
        "properties": {
          "business_id": {
            "type": "string",
            "enum": ["glass_soler", "esmeraldas_soler", "autos_soler", "inversiones_soler"]
          }
        },
        "required": ["business_id"]
      }
    },
    {
      "name": "score_lead",
      "description": "Score a customer message and return signals + recommendation",
      "input_schema": {
        "type": "object",
        "properties": {
          "user_id": {"type": "string"},
          "business_id": {"type": "string"},
          "message": {"type": "string"}
        },
        "required": ["user_id", "business_id", "message"]
      }
    },
    {
      "name": "schedule_appointment",
      "description": "Schedule an evaluation appointment for the customer",
      "input_schema": {
        "type": "object",
        "properties": {
          "business_id": {"type": "string"},
          "user_id": {"type": "string"},
          "preferred_date": {"type": "string"},
          "preferred_time": {"type": "string"},
          "location": {"type": "string", "enum": ["taller", "domicilio"]},
          "notes": {"type": "string"}
        },
        "required": ["business_id", "user_id", "preferred_date"]
      }
    },
    {
      "name": "request_human_handoff",
      "description": "Trigger handoff to a human agent",
      "input_schema": {
        "type": "object",
        "properties": {
          "business_id": {"type": "string"},
          "user_id": {"type": "string"},
          "reason": {"type": "string"},
          "urgency": {"type": "string", "enum": ["low", "medium", "high"]}
        },
        "required": ["business_id", "user_id", "reason"]
      }
    }
  ],
  "memory_store": {
    "enabled": true,
    "description": "Memoria persistente de conversaciones por usuario (sobrevive entre sesiones)",
    "scope": "per_user_per_business",
    "retention_days": 365
  },
  "skills": [
    "lead-scoring",
    "lead-enrichment",
    "appointment-scheduling",
    "csat-tracking",
    "objection-handling-spanish-cr"
  ],
  "knowledge_files": [
    "kb_glass_soler.json",
    "kb_esmeraldas.json",
    "kb_autos.json",
    "kb_inversiones.json"
  ],
  "rate_limiting": {
    "max_requests_per_minute": 60,
    "max_tokens_per_day": 1000000
  },
  "guardrails": {
    "block_topics": [
      "competidor_negativo",
      "compromiso_antibala_total",
      "datos_personales_terceros"
    ],
    "require_handoff_for": [
      "negociacion_precio_grande",
      "reclamo_legal",
      "queja_publica"
    ]
  },
  "integrations": {
    "webhook_destination": "https://allannsolis94.app.n8n.cloud/webhook/elena-managed-agent",
    "auth_header": "X-Webhook-Secret",
    "notify_on_handoff": true
  },
  "metadata": {
    "version": "2.0",
    "created": "2026-05-18",
    "maintainer": "Allann Solis",
    "businesses": ["glass_soler", "esmeraldas_soler", "autos_soler", "inversiones_soler"],
    "languages_supported": ["es", "en", "pt"],
    "deployed_locally_too": true,
    "local_endpoints": {
      "esmeraldas": "http://localhost:5000",
      "glass": "http://localhost:5001",
      "autos": "http://localhost:5002",
      "inversiones": "http://localhost:5003"
    }
  }
}
