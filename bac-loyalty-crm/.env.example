# Variables de entorno del CRM BAC Loyalty
# Copiar a .env (no versionado) y rellenar con valores reales.

# === Zolutium ===
ZOLUTIUM_BASE_URL=https://services.zolutium.com/api/v1
ZOLUTIUM_API_TOKEN=

# === Anthropic ===
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# === n8n Cloud ===
N8N_BASE_URL=https://allannsolis94.app.n8n.cloud
N8N_MCP_URL=https://allannsolis94.app.n8n.cloud/mcp-server/http
# Token de acceso para MCP (Settings -> MCP a nivel de instancia -> Detalles de conexion).
# Tambien va en ~/.claude/.env como N8N_MCP_TOKEN.
N8N_MCP_TOKEN=
N8N_API_KEY=

# === Workflow Agente 7 ===
# Umbral minimo de confianza para no descartar el batch.
KB_CONFIDENCE_THRESHOLD=0.6
# Salt para hash sha256 de IDs de contacto (evitar enviar PII a Claude).
PII_SALT=
