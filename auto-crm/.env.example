# ==============================================================
# CRM SOLER — Environment variables template
#
# Copy to .env.local and fill in your values.
# .env.local is gitignored. NEVER commit real values.
# ==============================================================

# ----- Meta Graph API ------------------------------------------------
META_API_VERSION=v25.0

# Long-lived user token (from "Soler" app, via App Secret exchange).
# Required for: Ads management, page discovery, pages_read_engagement.
META_ACCESS_TOKEN=

# Long-lived user token (from "Soler Inversiones" app).
# Required for: WhatsApp Business management, leads_retrieval.
META_ADS_TOKEN_INVERSIONES=

# App credentials (never expose)
META_APP_SECRET=
META_APP_SECRET_INVERSIONES=
META_CLIENT_TOKEN=
META_CLIENT_TOKEN_INVERSIONES=
META_APP_ID=
META_APP_ID_INVERSIONES=

# Webhook verification (must match value pasted in developers.facebook.com)
META_VERIFY_TOKEN=glass_soler_verify_2026

# Ad accounts (with act_ prefix)
META_ADS_ACCOUNT_GLASS=act_1101364862188478
META_ADS_ACCOUNT_ESMERALDAS=act_1868510380157902
META_ADS_ACCOUNT_AUTOS=act_2385776465260628
META_ADS_ACCOUNT_INR=

# Page tokens long-lived (never expire). Get from /me/accounts on respective app.
META_PAGE_TOKEN_GLASS=
META_PAGE_TOKEN_ESMERALDAS=
META_PAGE_TOKEN_AUTOS=
META_PAGE_TOKEN_INVERSIONES=

# ----- WhatsApp Business --------------------------------------------
META_WA_TOKEN=
META_WA_PHONE_ID_TEST=
META_WA_WABA_ID_TEST=
META_WA_TEST_PHONE_NUMBER=

# Production WA phone IDs (when migrated from test number)
META_WA_PHONE_ID_GLASS=
META_WA_PHONE_ID_ESMERALDAS=
META_WA_PHONE_ID_AUTOS=
META_WA_PHONE_ID_INVERSIONES=

# ----- Anthropic (Elena bot) ----------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ----- Database (Turso libSQL) --------------------------------------
# Local dev: leave both empty -> falls back to file:./data/crm.db
# Production (Vercel): set both. Get from https://app.turso.tech
#   1) Create database (e.g. crm-soler)
#   2) Copy "Database URL" (libsql://...)
#   3) Generate a token: turso db tokens create <db>  OR  via dashboard
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ----- Optional integrations ----------------------------------------
WEBHOOK_SECRET=
# Bot Python ecosystem (n8n) — only used locally for analytics
BOT_DB_PATH=
